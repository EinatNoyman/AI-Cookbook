{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@bmad-demo/feature-links": ["libs/feature-links/src/index.ts"],
      "@bmad-demo/feature-guidelines": ["libs/feature-guidelines/src/index.ts"],
      "@bmad-demo/feature-cookbook": ["libs/feature-cookbook/src/index.ts"],
      "@bmad-demo/feature-ai-tools": ["libs/feature-ai-tools/src/index.ts"],
      "@bmad-demo/shared-ui": ["libs/shared/ui/src/index.ts"],
      "@bmad-demo/shared-data": ["libs/shared/data/src/index.ts"],
      "@bmad-demo/shared-styles": ["libs/shared/styles/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
